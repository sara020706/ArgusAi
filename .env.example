# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# API server port (default: 8000)
ARGUS_PORT=8000

# Dashboard port (default: 8501)
DASHBOARD_PORT=8501

# Optional: protect the API with a key.
# If set, all requests need header: X-API-Key: <value>
ARGUS_API_KEY=

# Optional: AbuseIPDB API key for threat intelligence.
# Get a free key at https://www.abuseipdb.com/
ABUSEIPDB_KEY=

# Enable ML layer (requires scikit-learn)
ARGUS_ENABLE_ML=false

# SQLite database path (used in non-Docker mode)
ARGUS_DB_PATH=argus.db
